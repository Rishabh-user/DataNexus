# Application
APP_NAME=DataNexus
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://datanexus:datanexus@localhost:5432/datanexus
DATABASE_URL_SYNC=postgresql://datanexus:datanexus@localhost:5432/datanexus

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Microsoft Graph / OneDrive
MS_CLIENT_ID=a23fe24f-bdff-47db-b2ef-c1c3d9e6830d
MS_CLIENT_SECRET=851aaf47-36ab-4ee4-8e78-ce9c5b625fd5
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:8000/api/v1/onedrive/callback
MS_SCOPES=Files.Read,Files.Read.All,User.Read,offline_access

# Storage
UPLOAD_DIR=./uploads
REPORTS_DIR=./generated_reports
MAX_FILE_SIZE_MB=100

# Encryption
FERNET_KEY=your-fernet-key-generate-with-cryptography

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Logging
LOG_LEVEL=INFO
